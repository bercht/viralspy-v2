<div class="mb-8">
  <h1 class="text-2xl font-bold text-gray-900"><%= t("competitors.new.title") %></h1>
  <p class="mt-1 text-sm text-gray-600"><%= t("competitors.new.subtitle") %></p>
</div>

<div class="max-w-xl rounded-lg border border-gray-200 bg-white p-6">
  <%= form_with model: @competitor, class: "space-y-4" do |f| %>
    <% if @competitor.errors.any? %>
      <div class="rounded-lg border border-red-200 bg-red-50 p-4">
        <ul class="list-inside list-disc text-sm text-red-800">
          <% @competitor.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :instagram_handle, t("competitors.form.handle"), class: "block text-sm font-medium text-gray-700" %>
      <div class="mt-1 flex items-center rounded-lg border border-gray-300 bg-white focus-within:border-gray-900 focus-within:ring-1 focus-within:ring-gray-900">
        <span class="pl-3 text-gray-500">@</span>
        <%= f.text_field :instagram_handle,
            class: "block w-full border-0 bg-transparent px-2 py-2 text-gray-900 focus:outline-none focus:ring-0",
            placeholder: "imobiliariaxyz" %>
      </div>
      <p class="mt-1 text-xs text-gray-500"><%= t("competitors.form.handle_hint") %></p>
    </div>

    <div class="flex items-center justify-end gap-3 pt-4">
      <%= link_to t("competitors.form.cancel"), competitors_path,
          class: "text-sm font-medium text-gray-700 hover:text-gray-900" %>
      <%= f.submit t("competitors.form.submit"),
          class: "rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-800 cursor-pointer" %>
    </div>
  <% end %>
</div>
