<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-light text-slate-900">Meus Perfis</h1>
    <%= link_to "Adicionar Perfil", new_own_profile_path,
        class: "bg-blue-600 hover:bg-sky-400 text-white rounded-full px-6 py-2.5 font-medium transition-all hover:scale-105 inline-block" %>
  </div>

  <% if @own_profiles.empty? %>
    <div class="text-center py-16">
      <p class="text-slate-500 text-lg font-light mb-6">Nenhum perfil cadastrado ainda.</p>
      <%= link_to "Adicionar meu perfil", new_own_profile_path,
          class: "bg-blue-600 hover:bg-sky-400 text-white rounded-full px-6 py-2.5 font-medium transition-all hover:scale-105 inline-block" %>
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @own_profiles.each do |profile| %>
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6 space-y-4">
          <div class="flex items-start justify-between">
            <div>
              <p class="font-semibold text-slate-900">@<%= profile.instagram_handle %></p>
              <% if profile.full_name.present? %>
                <p class="text-sm text-slate-500"><%= profile.full_name %></p>
              <% end %>
            </div>
            <% if profile.token_valid? %>
              <% if profile.token_expiring_soon? %>
                <span class="rounded-full text-xs px-2 py-0.5 font-medium bg-yellow-100 text-yellow-800">Token expira em breve</span>
              <% else %>
                <span class="rounded-full text-xs px-2 py-0.5 font-medium bg-green-100 text-green-800">Token ativo</span>
              <% end %>
            <% else %>
              <span class="rounded-full text-xs px-2 py-0.5 font-medium bg-red-100 text-red-800">Token inválido</span>
            <% end %>
          </div>
          <div class="flex gap-2 pt-2">
            <%= link_to "Ver Dashboard", own_profile_path(profile),
                class: "flex-1 text-center bg-blue-600 hover:bg-sky-400 text-white rounded-full px-4 py-2 text-sm font-medium transition-all" %>
            <%= button_to "Sincronizar", sync_own_profile_path(profile),
                class: "flex-1 text-center bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-full px-4 py-2 text-sm font-medium transition-all" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
