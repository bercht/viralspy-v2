<nav class="border-b border-gray-200 bg-white">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <%= link_to authenticated_root_path, class: "flex items-center gap-2" do %>
      <span class="text-lg font-semibold text-gray-900">ViralSpy</span>
    <% end %>

    <div class="flex items-center gap-6">
      <%= link_to t("nav.dashboard"), dashboard_path, class: "text-sm font-medium text-gray-700 hover:text-gray-900" %>
      <%= link_to t("nav.competitors"), competitors_path, class: "text-sm font-medium text-gray-700 hover:text-gray-900" %>

      <div class="flex items-center gap-3 border-l border-gray-200 pl-6">
        <span class="text-sm text-gray-600"><%= current_user.first_name %></span>
        <%= button_to t("nav.logout"), destroy_user_session_path, method: :delete,
            class: "text-sm font-medium text-gray-700 hover:text-gray-900",
            form: { class: "inline" } %>
      </div>
    </div>
  </div>
</nav>
