# Rails
RAILS_MASTER_KEY=
SECRET_KEY_BASE=
VIRALSPY_HOST=viralspy.curt.com.br

# Database
# DATABASE_URL — obrigatória. Construa a partir de POSTGRES_USER/PASSWORD/DB abaixo.
# Em produção (dentro do docker-compose), host é "db" (nome do serviço).
# Exemplo:
# DATABASE_URL=postgres://viralspy:SENHA_AQUI@db:5432/viralspy_production
DATABASE_URL=
POSTGRES_USER=viralspy
POSTGRES_PASSWORD=
POSTGRES_DB=viralspy_production

# Redis
REDIS_URL=redis://redis:6379/0
SIDEKIQ_REDIS_URL=redis://redis:6379/1

# Encryption (vai pra credentials em produção)
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# Scraping
APIFY_API_TOKEN=
SCRAPING_PROVIDER=apify
SCRAPING_POSTS_PER_ANALYSIS=30

# LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_LLM_PROVIDER=openai

# Transcription
# Provider: "openai" (padrão) ou "assemblyai"
TRANSCRIPTION_PROVIDER=openai
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# AssemblyAI (provider alternativo — ativar com TRANSCRIPTION_PROVIDER=assemblyai)
# Obter em: https://www.assemblyai.com/dashboard/api-keys
# Free tier: US$ 50 de crédito na signup (~40.000 reels de ~40s)
ASSEMBLYAI_API_KEY=

# Feature flags
ENABLE_SIGNUP=true

# Backup (Cloudflare R2 — S3-compatible)
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Obter ACCOUNT_ID em: Cloudflare dashboard → R2 → sidebar
# Gerar API token em: R2 → Manage R2 API Tokens → Create API Token
# Region R2 é literalmente a string "auto" (não é região geográfica)
BACKUP_S3_ENDPOINT=https://CHANGE_ME_ACCOUNT_ID.r2.cloudflarestorage.com
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_BUCKET=viralspy-backups
BACKUP_S3_REGION=auto
