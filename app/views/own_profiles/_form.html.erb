<%= form_with model: own_profile, class: "space-y-6" do |f| %>
  <% if own_profile.errors.any? %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4">
      <p class="text-sm font-medium text-red-800 mb-2">
        <%= pluralize(own_profile.errors.count, "erro") %> encontrado(s):
      </p>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
        <% own_profile.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :instagram_handle, "Handle do Instagram", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :instagram_handle, placeholder: "@seuhandle",
        class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div>
    <%= f.label :full_name, "Nome completo", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :full_name,
        class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div>
    <%= f.label :bio, "Bio", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_area :bio, rows: 3,
        class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div>
    <%= f.label :voice_notes, "Tom de voz e estilo", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <p class="text-xs text-slate-500 mb-1">Descreva suas expressões, o que evitar, como você fala com seu público.</p>
    <%= f.text_area :voice_notes, rows: 4,
        class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div>
    <%= f.label :meta_access_token, "Token Meta (Graph API)", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <p class="text-xs text-slate-500 mb-1">Gere em Meta for Developers. Expira em 60 dias.</p>
    <%= f.text_field :meta_access_token,
        class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div>
    <%= f.label :meta_token_expires_at, "Validade do token", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.datetime_local_field :meta_token_expires_at,
        class: "w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit own_profile.new_record? ? "Adicionar Perfil" : "Salvar Alterações",
        class: "bg-blue-600 hover:bg-sky-400 text-white rounded-full px-6 py-2.5 font-medium transition-all hover:scale-105 cursor-pointer" %>
    <%= link_to "Cancelar", own_profiles_path,
        class: "text-slate-500 hover:text-slate-700 px-4 py-2 text-sm" %>
  </div>
<% end %>
