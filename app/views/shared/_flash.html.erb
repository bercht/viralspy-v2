<% flash.each do |type, message| %>
  <% classes = case type.to_sym
     when :notice then "border-emerald-200 bg-emerald-50 text-emerald-900"
     when :alert, :error then "border-red-200 bg-red-50 text-red-900"
     else "border-gray-200 bg-gray-50 text-gray-900"
     end %>
  <div class="mb-6 rounded-lg border px-4 py-3 text-sm <%= classes %>">
    <%= message %>
  </div>
<% end %>
