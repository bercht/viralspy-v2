#!/bin/bash
set -e

# Run migrations when starting the web server (both rails server and puma)
if [ "$1" = "bin/rails" ] && [ "$2" = "server" ]; then
  bundle exec rails db:prepare
elif [ "$1" = "bundle" ] && [ "$2" = "exec" ] && [ "$3" = "puma" ]; then
  bundle exec rails db:prepare
fi

rm -f /rails/tmp/pids/server.pid
exec "$@"
