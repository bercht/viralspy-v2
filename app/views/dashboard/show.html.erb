<div class="min-h-screen">
  <header class="bg-white border-b border-gray-200">
    <div class="mx-auto max-w-5xl px-4 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-lg font-semibold text-gray-900">ViralSpy</span>
        <span class="text-sm text-gray-500">/ <%= current_tenant.name %></span>
      </div>
      <div class="flex items-center gap-4 text-sm">
        <span class="text-gray-700"><%= current_user.full_name %></span>
        <%= button_to "Sair",
              destroy_user_session_path,
              method: :delete,
              data: { turbo_method: :delete },
              class: "text-gray-600 hover:text-gray-900" %>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-5xl px-4 py-8">
    <h1 class="text-2xl font-semibold text-gray-900 mb-2">Bem-vindo, <%= current_user.first_name %>!</h1>
    <p class="text-gray-600">Sua conta <strong><%= current_tenant.name %></strong> está pronta. Em breve você vai poder adicionar concorrentes e rodar análises aqui.</p>
  </main>
</div>
