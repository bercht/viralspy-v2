<nav class="bg-surface-dark">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap items-center justify-between gap-x-6 gap-y-2 py-3 sm:py-4">
      <%= link_to authenticated_root_path, class: "flex items-center gap-2" do %>
        <span class="text-heading-sm font-semibold tracking-tight text-text-on-dark">ViralSpy</span>
      <% end %>

      <div class="flex flex-wrap items-center gap-3 sm:gap-6">
        <%= link_to t("nav.dashboard"), dashboard_path,
            class: "text-body-sm text-text-on-dark-muted transition-colors hover:text-text-on-dark sm:text-button" %>
        <%= link_to t("nav.competitors"), competitors_path,
            class: "text-body-sm text-text-on-dark-muted transition-colors hover:text-text-on-dark sm:text-button" %>
        <%= link_to t("nav.settings"), settings_api_keys_path,
            class: "text-body-sm text-text-on-dark-muted transition-colors hover:text-text-on-dark sm:text-button" %>

        <div class="flex items-center gap-2 border-l border-white/20 pl-3 sm:gap-3 sm:pl-6">
          <span class="hidden text-body-sm text-text-on-dark-muted sm:inline"><%= current_user.first_name %></span>
          <%= button_to t("nav.logout"), destroy_user_session_path, method: :delete,
              class: "text-body-sm text-text-on-dark-muted transition-colors hover:text-text-on-dark sm:text-button",
              form: { class: "inline" } %>
        </div>
      </div>
    </div>
  </div>
</nav>
