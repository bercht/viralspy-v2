<%= form_with model: own_profile, class: "space-y-6" do |f| %>
  <% if own_profile.errors.any? %>
    <div class="rounded-card border border-semantic-danger/30 bg-semantic-danger-bg p-4">
      <p class="text-body-sm font-medium text-semantic-danger mb-2">
        <%= pluralize(own_profile.errors.count, "erro") %> encontrado(s):
      </p>
      <ul class="list-disc list-inside text-body-sm text-semantic-danger space-y-1">
        <% own_profile.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :instagram_handle, "Handle do Instagram", class: "block text-body-sm font-medium text-text-body mb-1" %>
    <%= f.text_field :instagram_handle, placeholder: "@seuhandle",
        class: "w-full rounded-input border border-border-default bg-surface-canvas px-3 py-2 text-body text-text-body placeholder:text-text-subtle focus:border-brand-primary focus:outline-none focus:shadow-focus" %>
  </div>

  <div>
    <%= f.label :full_name, "Nome completo", class: "block text-body-sm font-medium text-text-body mb-1" %>
    <%= f.text_field :full_name,
        class: "w-full rounded-input border border-border-default bg-surface-canvas px-3 py-2 text-body text-text-body placeholder:text-text-subtle focus:border-brand-primary focus:outline-none focus:shadow-focus" %>
  </div>

  <div>
    <%= f.label :bio, "Bio", class: "block text-body-sm font-medium text-text-body mb-1" %>
    <%= f.text_area :bio, rows: 3,
        class: "w-full rounded-input border border-border-default bg-surface-canvas px-3 py-2 text-body text-text-body placeholder:text-text-subtle focus:border-brand-primary focus:outline-none focus:shadow-focus" %>
  </div>

  <div>
    <%= f.label :voice_notes, "Tom de voz e estilo", class: "block text-body-sm font-medium text-text-body mb-1" %>
    <p class="text-caption text-text-muted mb-1">Descreva suas expressões, o que evitar, como você fala com seu público.</p>
    <%= f.text_area :voice_notes, rows: 4,
        class: "w-full rounded-input border border-border-default bg-surface-canvas px-3 py-2 text-body text-text-body placeholder:text-text-subtle focus:border-brand-primary focus:outline-none focus:shadow-focus" %>
  </div>

  <div>
    <%= f.label :meta_access_token, "Token Meta (Graph API)", class: "block text-body-sm font-medium text-text-body mb-1" %>
    <p class="text-caption text-text-muted mb-1">Gere em Meta for Developers. Expira em 60 dias.</p>
    <%= f.text_field :meta_access_token,
        class: "w-full rounded-input border border-border-default bg-surface-canvas px-3 py-2 text-body text-text-body placeholder:text-text-subtle focus:border-brand-primary focus:outline-none focus:shadow-focus" %>
  </div>

  <div>
    <%= f.label :meta_token_expires_at, "Validade do token", class: "block text-body-sm font-medium text-text-body mb-1" %>
    <%= f.datetime_local_field :meta_token_expires_at,
        class: "w-full rounded-input border border-border-default bg-surface-canvas px-3 py-2 text-body text-text-body placeholder:text-text-subtle focus:border-brand-primary focus:outline-none focus:shadow-focus" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit own_profile.new_record? ? "Adicionar Perfil" : "Salvar Alterações",
        class: "rounded-pill bg-brand-primary px-6 py-2.5 text-button text-text-on-dark transition-all duration-[180ms] ease-out hover:bg-brand-primary-hover hover:scale-[1.02] focus:outline-none focus:shadow-focus-strong cursor-pointer" %>
    <%= link_to "Cancelar", own_profiles_path,
        class: "text-body-sm text-text-muted hover:text-text-body px-4 py-2" %>
  </div>
<% end %>
