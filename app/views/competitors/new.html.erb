<div class="mx-auto max-w-xl">
  <header class="mb-8">
    <%= link_to t("competitors.index.title"), competitors_path,
        class: "text-body-sm text-brand-primary hover:text-brand-primary-hover" %>
    <h1 class="mt-2 text-display text-text-display"><%= t("competitors.new.title") %></h1>
    <p class="mt-2 text-body text-text-muted"><%= t("competitors.new.subtitle") %></p>
  </header>

  <%= form_with model: @competitor, class: "space-y-6" do |f| %>
    <% if @competitor.errors.any? %>
      <div class="rounded-card border border-semantic-danger/30 bg-semantic-danger-bg px-4 py-3">
        <ul class="text-body-sm text-semantic-danger">
          <% @competitor.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <article class="rounded-card border border-border-subtle bg-surface-canvas p-6 shadow-card">
      <div>
        <%= f.label :instagram_handle, t("competitors.form.handle"),
            class: "block text-body-sm font-medium text-text-body" %>

        <div class="mt-1 flex items-center rounded-input border border-border-default bg-surface-canvas focus-within:border-brand-primary focus-within:shadow-focus">
          <span class="pl-3 text-body text-text-subtle" aria-hidden="true">@</span>
          <%= f.text_field :instagram_handle,
              autofocus: true,
              autocomplete: "off",
              placeholder: t("competitors.form.handle_hint"),
              class: "block w-full border-0 bg-transparent px-2 py-2 text-body text-text-body placeholder:text-text-subtle focus:outline-none focus:ring-0" %>
        </div>

        <p class="mt-2 text-caption text-text-muted">
          <%= t("competitors.form.handle_hint") %>
        </p>
      </div>
    </article>

    <div class="flex items-center justify-end gap-3">
      <%= link_to t("competitors.form.cancel"), competitors_path,
          class: "rounded-pill px-4 py-2 text-button text-text-muted transition-colors hover:text-text-body" %>
      <%= f.submit t("competitors.form.submit"),
          class: "rounded-pill bg-brand-primary px-5 py-2 text-button text-text-on-dark transition-colors hover:bg-brand-primary-hover focus:outline-none focus:shadow-focus-strong cursor-pointer" %>
    </div>
  <% end %>
</div>
