<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8">
      <h1 class="text-2xl font-semibold text-gray-900 mb-6"><%= t('devise.registrations.new.title') %></h1>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <% if resource.errors.any? %>
          <div class="rounded-md bg-red-50 p-4 text-sm text-red-800 border border-red-200">
            <ul class="list-disc list-inside space-y-1">
              <% resource.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= label_tag "user[account_name]", t('devise.registrations.account_name_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= text_field_tag "user[account_name]", nil, required: true, autofocus: true,
                class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :first_name, t('devise.registrations.first_name_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :first_name, required: true,
                  class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
          </div>
          <div>
            <%= f.label :last_name, t('devise.registrations.last_name_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :last_name, required: true,
                  class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
          </div>
        </div>

        <div>
          <%= f.label :email, t('devise.registrations.email_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, required: true, autocomplete: "email",
                class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        </div>

        <div>
          <%= f.label :password, t('devise.registrations.password_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, required: true, autocomplete: "new-password",
                class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
          <% if @minimum_password_length %>
            <p class="mt-1 text-xs text-gray-500">Mínimo <%= @minimum_password_length %> caracteres.</p>
          <% end %>
        </div>

        <%= f.submit t('devise.registrations.new.submit'),
              class: "w-full rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer" %>
      <% end %>

      <div class="mt-6 text-center text-sm text-gray-600">
        <%= link_to t('devise.registrations.already_registered'), new_session_path(resource_name), class: "text-indigo-600 hover:text-indigo-700" %>
      </div>
    </div>
  </div>
</div>
