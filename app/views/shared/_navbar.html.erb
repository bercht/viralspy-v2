<nav class="bg-surface-dark">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <%= link_to authenticated_root_path, class: "flex items-center gap-2" do %>
      <span class="text-heading-sm font-semibold tracking-tight text-text-on-dark">ViralSpy</span>
    <% end %>

    <div class="flex items-center gap-6">
      <%= link_to t("nav.dashboard"), dashboard_path,
          class: "text-button text-text-on-dark-muted transition-colors hover:text-text-on-dark" %>
      <%= link_to t("nav.competitors"), competitors_path,
          class: "text-button text-text-on-dark-muted transition-colors hover:text-text-on-dark" %>

      <div class="flex items-center gap-3 border-l border-white/20 pl-6">
        <span class="text-body-sm text-text-on-dark-muted"><%= current_user.first_name %></span>
        <%= button_to t("nav.logout"), destroy_user_session_path, method: :delete,
            class: "text-button text-text-on-dark-muted transition-colors hover:text-text-on-dark",
            form: { class: "inline" } %>
      </div>
    </div>
  </div>
</nav>
