<nav class="sticky top-0 z-50 bg-black w-full" data-controller="mobile-menu">
  <div class="mx-auto max-w-[1600px] px-4 md:px-8 lg:px-12">
    <div class="flex items-center justify-between h-16">

      <%# Logo %>
      <%= link_to authenticated_root_path, class: "flex items-center gap-2 shrink-0", aria: { label: "ViralSpy — início" } do %>
        <span class="text-white font-bold text-xl tracking-tight font-sans">ViralSpy</span>
      <% end %>

      <%# Desktop nav links %>
      <div class="hidden md:flex items-center gap-1">
        <% nav_links = [
          { label: t("nav.dashboard"),    path: dashboard_path,        match: [dashboard_path] },
          { label: t("nav.competitors"),  path: competitors_path,       match: [competitors_path] },
          { label: t("nav.playbooks"),    path: playbooks_path,         match: [playbooks_path] },
          { label: t("nav.own_profiles"), path: own_profiles_path,      match: [own_profiles_path] },
          { label: t("nav.medias"),       path: generated_medias_path,  match: [generated_medias_path] },
        ] %>

        <% nav_links.each do |link| %>
          <% active = link[:match].any? { |p| current_page?(p) } %>
          <%= link_to link[:label], link[:path],
              class: "px-3 py-1.5 rounded-full text-sm font-medium transition-colors duration-150 #{active ? 'text-white bg-white/10' : 'text-white/70 hover:text-white hover:bg-white/5'}" %>
        <% end %>
      </div>

      <%# Desktop user area %>
      <div class="hidden md:flex items-center gap-3">
        <details class="relative [&>summary::-webkit-details-marker]:hidden [&>summary::marker]:hidden group">
          <summary class="flex items-center gap-2 cursor-pointer list-none select-none rounded-full px-3 py-1.5 transition-colors duration-150 hover:bg-white/10 focus:outline-none focus-visible:shadow-focus" aria-label="Menu do usuário">
            <div class="w-7 h-7 rounded-full bg-brand-primary flex items-center justify-center shrink-0">
              <span class="text-white text-xs font-bold leading-none"><%= current_user.first_name&.first&.upcase %></span>
            </div>
            <span class="text-white/90 text-sm font-medium"><%= current_user.first_name %></span>
            <svg class="w-3.5 h-3.5 text-white/50 transition-transform duration-150 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>

          <div class="absolute right-0 top-full mt-2 w-48 rounded-xl bg-[#111] border border-white/10 shadow-xl shadow-black/50 overflow-hidden">
            <%= link_to settings_api_keys_path,
                class: "flex items-center gap-2.5 px-4 py-3 text-sm text-white/80 hover:text-white hover:bg-white/5 transition-colors",
                data: { turbo_prefetch: "false" } do %>
              <svg class="w-4 h-4 shrink-0 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <%= t("nav.settings") %>
            <% end %>
            <div class="border-t border-white/10">
              <%= button_to destroy_user_session_path, method: :delete,
                  class: "w-full flex items-center gap-2.5 px-4 py-3 text-sm text-white/80 hover:text-white hover:bg-white/5 transition-colors text-left",
                  form: { class: "w-full" } do %>
                <svg class="w-4 h-4 shrink-0 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                <%= t("nav.logout") %>
              <% end %>
            </div>
          </div>
        </details>
      </div>

      <%# Mobile hamburger button %>
      <button type="button"
              class="md:hidden rounded-card p-2 text-text-on-dark/70 hover:text-text-on-dark hover:bg-white/10 transition-colors focus:outline-none focus-visible:shadow-focus"
              data-action="click->mobile-menu#toggle"
              aria-label="Abrir menu de navegação">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <%# Mobile drawer %>
  <div class="hidden md:hidden bg-black border-t border-white/10" data-mobile-menu-target="panel">
    <div class="px-4 py-4 flex flex-col gap-1">
      <% nav_links = [
        { label: t("nav.dashboard"),    path: dashboard_path },
        { label: t("nav.competitors"),  path: competitors_path },
        { label: t("nav.playbooks"),    path: playbooks_path },
        { label: t("nav.own_profiles"), path: own_profiles_path },
        { label: t("nav.medias"),       path: generated_medias_path },
      ] %>

      <% nav_links.each do |link| %>
        <% active = current_page?(link[:path]) %>
        <%= link_to link[:label], link[:path],
            class: "flex items-center px-4 py-3 rounded-lg text-base font-medium transition-colors border-b border-white/5 last:border-b-0 #{active ? 'text-white bg-white/10' : 'text-white/70 hover:text-white hover:bg-white/5'}" %>
      <% end %>

      <div class="mt-3 pt-3 border-t border-white/10 flex items-center justify-between">
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-full bg-brand-primary flex items-center justify-center shrink-0">
            <span class="text-white text-xs font-bold"><%= current_user.first_name&.first&.upcase %></span>
          </div>
          <span class="text-white/80 text-sm font-medium"><%= current_user.first_name %></span>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to t("nav.settings"), settings_api_keys_path,
              class: "rounded-full px-3 py-1.5 text-sm text-white/70 hover:text-white hover:bg-white/10 transition-colors" %>
          <%= button_to t("nav.logout"), destroy_user_session_path, method: :delete,
              class: "rounded-full px-4 py-1.5 text-sm font-medium bg-brand-primary text-text-on-dark hover:bg-brand-primary-hover transition-colors",
              form: { class: "inline-block" } %>
        </div>
      </div>
    </div>
  </div>
</nav>
