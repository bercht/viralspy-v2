<div class="rounded-lg border border-gray-200 bg-white p-6">
  <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-700">
    <%= t("post_type.#{type}_plural") %> (<%= posts.size %>)
  </h3>
  <div class="space-y-3">
    <% posts.each_with_index do |post, idx| %>
      <div class="flex gap-4 border-t border-gray-100 pt-3 first:border-t-0 first:pt-0">
        <div class="flex-shrink-0 text-sm font-medium text-gray-400">#<%= idx + 1 %></div>
        <div class="min-w-0 flex-1">
          <p class="line-clamp-2 text-sm text-gray-900"><%= post.caption.presence || t("analyses.show.top_posts.no_caption") %></p>
          <div class="mt-2 flex items-center gap-4 text-xs text-gray-500">
            <span><%= number_with_delimiter(post.likes_count) %> curtidas</span>
            <span><%= number_with_delimiter(post.comments_count) %> comentários</span>
            <% if post.video_view_count.present? %>
              <span><%= number_with_delimiter(post.video_view_count) %> views</span>
            <% end %>
            <span class="ml-auto font-medium text-gray-700"><%= t("analyses.show.top_posts.score") %>: <%= post.quality_score&.round(2) || "—" %></span>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
