<div class="rounded-lg border border-red-200 bg-red-50 p-8">
  <h2 class="text-lg font-semibold text-red-900"><%= t("analyses.show.failed.title") %></h2>
  <p class="mt-2 text-sm text-red-800">
    <%= @analysis.error_message.presence || t("analyses.show.failed.default_message") %>
  </p>
  <div class="mt-6">
    <%= button_to t("analyses.show.failed.retry"),
        competitor_analyses_path(@competitor), method: :post,
        class: "rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-800" %>
  </div>
</div>
