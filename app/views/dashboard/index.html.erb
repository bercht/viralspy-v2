<div class="mx-auto max-w-6xl">
  <header class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-display text-text-display"><%= t("dashboard.title") %></h1>
      <p class="mt-2 text-body text-text-muted"><%= t("dashboard.subtitle") %></p>
    </div>
    <%= link_to t("dashboard.new_competitor"), new_competitor_path,
        class: "rounded-pill bg-brand-primary px-5 py-2 text-button text-text-on-dark transition-colors hover:bg-brand-primary-hover focus:outline-none focus:shadow-focus-strong" %>
  </header>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <section class="rounded-card border border-border-subtle bg-surface-canvas p-6 shadow-card">
      <h2 class="mb-4 text-heading text-text-body"><%= t("dashboard.recent_competitors") %></h2>

      <% if @competitors.any? %>
        <ul class="divide-y divide-border-subtle">
          <% @competitors.each do |competitor| %>
            <li class="py-3">
              <%= link_to competitor_path(competitor), class: "flex items-center justify-between -mx-2 px-2 transition-colors hover:bg-surface-base rounded-sm" do %>
                <div>
                  <p class="text-body-sm font-medium text-text-body">@<%= competitor.instagram_handle %></p>
                  <p class="text-caption text-text-muted">
                    <%= t("dashboard.analyses_count", count: competitor.analyses.size) %>
                  </p>
                </div>
                <span class="text-body-sm text-text-subtle" aria-hidden="true">&rarr;</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-body-sm text-text-muted"><%= t("dashboard.no_competitors") %></p>
      <% end %>
    </section>

    <section class="rounded-card border border-border-subtle bg-surface-canvas p-6 shadow-card">
      <h2 class="mb-4 text-heading text-text-body"><%= t("dashboard.recent_analyses") %></h2>

      <% if @recent_analyses.any? %>
        <ul class="divide-y divide-border-subtle">
          <% @recent_analyses.each do |analysis| %>
            <li class="py-3">
              <%= link_to competitor_analysis_path(analysis.competitor, analysis),
                  class: "flex items-center justify-between -mx-2 px-2 transition-colors hover:bg-surface-base rounded-sm" do %>
                <div>
                  <p class="text-body-sm font-medium text-text-body">@<%= analysis.competitor.instagram_handle %></p>
                  <p class="text-caption text-text-muted">
                    <%= l(analysis.created_at, format: :short) %>
                  </p>
                </div>
                <%= render "shared/status_badge", status: analysis.status %>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-body-sm text-text-muted"><%= t("dashboard.no_analyses") %></p>
      <% end %>
    </section>
  </div>
</div>
