<section class="mb-8 rounded-feature border border-border-subtle bg-surface-canvas p-6 shadow-card">
  <h2 class="mb-4 text-heading text-text-body"><%= t("analyses.show.profile_metrics.title") %></h2>
  <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
    <div>
      <p class="text-caption uppercase tracking-wider text-text-muted"><%= t("analyses.show.profile_metrics.posts_per_week") %></p>
      <p class="mt-1 text-2xl font-semibold text-text-body"><%= profile_metrics["posts_per_week"] || "—" %></p>
    </div>
    <div>
      <p class="text-caption uppercase tracking-wider text-text-muted"><%= t("analyses.show.profile_metrics.avg_likes") %></p>
      <p class="mt-1 text-2xl font-semibold text-text-body"><%= number_with_delimiter(profile_metrics["avg_likes_per_post"] || 0) %></p>
    </div>
    <div>
      <p class="text-caption uppercase tracking-wider text-text-muted"><%= t("analyses.show.profile_metrics.avg_comments") %></p>
      <p class="mt-1 text-2xl font-semibold text-text-body"><%= number_with_delimiter(profile_metrics["avg_comments_per_post"] || 0) %></p>
    </div>
    <div>
      <p class="text-caption uppercase tracking-wider text-text-muted"><%= t("analyses.show.profile_metrics.engagement_rate") %></p>
      <p class="mt-1 text-2xl font-semibold text-text-body">
        <%= number_to_percentage((profile_metrics["avg_engagement_rate"] || 0) * 100, precision: 2) %>
      </p>
    </div>
  </div>

  <% if profile_metrics["content_mix"].present? %>
    <div class="mt-6 border-t border-border-subtle pt-6">
      <p class="mb-2 text-caption uppercase tracking-wider text-text-muted"><%= t("analyses.show.profile_metrics.content_mix") %></p>
      <div class="flex flex-wrap gap-4">
        <% profile_metrics["content_mix"].each do |type, pct| %>
          <div class="flex items-center gap-2">
            <span class="text-body-sm font-medium text-text-body"><%= t("post_type.#{type}") %>:</span>
            <span class="text-body-sm text-text-muted"><%= number_to_percentage(pct * 100, precision: 0) %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if profile_metrics["top_hashtags"].present? %>
    <div class="mt-6 border-t border-border-subtle pt-6">
      <p class="mb-2 text-caption uppercase tracking-wider text-text-muted"><%= t("analyses.show.profile_metrics.top_hashtags") %></p>
      <div class="flex flex-wrap gap-2">
        <% profile_metrics["top_hashtags"].each do |tag| %>
          <span class="rounded-pill bg-surface-base px-3 py-1 text-xs font-medium text-text-body">#<%= tag %></span>
        <% end %>
      </div>
    </div>
  <% end %>
</section>

<section class="mb-8">
  <h2 class="mb-4 text-heading text-text-body"><%= t("analyses.show.top_posts.title") %></h2>
  <% if posts_by_type.any? %>
    <div class="space-y-6">
      <% %w[reel carousel image].each do |type| %>
        <% posts = posts_by_type[type] %>
        <% next if posts.blank? %>
        <%= render "analyses/posts_by_type", type: type, posts: posts.sort_by { |p| -(p.quality_score || 0) } %>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-feature border border-border-subtle bg-surface-canvas p-6 text-center text-body-sm text-text-muted shadow-card">
      <%= t("analyses.show.top_posts.empty") %>
    </div>
  <% end %>
</section>

<section>
  <h2 class="mb-4 text-heading text-text-body"><%= t("analyses.show.suggestions.title") %></h2>

  <div class="mb-6 rounded-card border border-border-subtle bg-surface-canvas p-6 shadow-card">
    <%= form_with url: content_suggestions_generate_index_path(
                         competitor_id: analysis.competitor_id,
                         analysis_id: analysis.id),
                  method: :post,
                  data: { turbo: true } do |f| %>
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end">
        <div class="flex flex-col gap-1">
          <%= f.label :content_type, "Tipo de conteúdo",
                      class: "text-caption font-medium text-text-muted" %>
          <%= f.select :content_type,
                       [["Reel", "reel"], ["Carrossel", "carousel"], ["Story", "story"]],
                       {},
                       class: "rounded-input border border-border-default bg-surface-canvas px-3 py-2 text-body text-text-body focus:border-brand-primary focus:outline-none focus:shadow-focus" %>
        </div>

        <div class="flex flex-col gap-1">
          <%= f.label :quantity, "Quantidade",
                      class: "text-caption font-medium text-text-muted" %>
          <%= f.select :quantity,
                       [[1, 1], [2, 2], [3, 3]],
                       { selected: 2 },
                       class: "rounded-input border border-border-default bg-surface-canvas px-3 py-2 text-body text-text-body focus:border-brand-primary focus:outline-none focus:shadow-focus" %>
        </div>

        <%= f.submit "Gerar sugestões",
                     class: "rounded-pill bg-brand-primary px-5 py-2 text-button text-text-on-dark transition-colors hover:bg-brand-primary-hover focus:outline-none focus:shadow-focus-strong cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed",
                     data: { turbo_submits_with: "Gerando..." } %>
      </div>
    <% end %>
  </div>

  <div id="suggestions-generate-error"></div>

  <div id="suggestions-section">
    <% if suggestions.any? %>
      <div class="space-y-4">
        <% suggestions.each do |suggestion| %>
          <%= render "analyses/suggestion_card", suggestion: suggestion %>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-feature border border-border-subtle bg-surface-canvas p-6 text-center text-body-sm text-text-muted shadow-card">
        <%= t("analyses.show.suggestions.empty") %>
      </div>
    <% end %>
  </div>
</section>
