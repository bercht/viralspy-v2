<% if flash.any? %>
  <div class="max-w-3xl mx-auto mb-8 space-y-3">
    <% flash.each do |type, message| %>
      <% bg_classes = case type.to_sym
         when :notice, :success then "bg-brand-primary text-text-on-dark"
         when :alert, :error    then "bg-semantic-danger text-text-on-dark"
         else                        "bg-surface-base text-text-body border border-border-subtle"
         end %>

      <div class="rounded-xl px-4 py-3 shadow-[0_5px_9px_0_rgba(0,0,0,0.08)] flex items-start gap-3 <%= bg_classes %>"
           data-controller="flash">

        <%# Icon %>
        <% if [:notice, :success].include?(type.to_sym) %>
          <svg class="w-5 h-5 shrink-0 mt-0.5 opacity-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
          </svg>
        <% elsif [:alert, :error].include?(type.to_sym) %>
          <svg class="w-5 h-5 shrink-0 mt-0.5 opacity-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
          </svg>
        <% else %>
          <svg class="w-5 h-5 shrink-0 mt-0.5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        <% end %>

        <span class="text-sm font-medium leading-relaxed"><%= message %></span>
      </div>
    <% end %>
  </div>
<% end %>
