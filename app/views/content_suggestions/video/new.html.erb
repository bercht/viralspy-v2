<div class="mx-auto max-w-lg px-4 py-6">
  <div class="mb-4">
    <%= link_to "← Voltar",
          competitor_analysis_path(@content_suggestion.analysis.competitor, @content_suggestion.analysis),
          class: "text-body-sm text-text-muted hover:text-text-body" %>
  </div>

  <h1 class="mb-6 text-heading text-text-body">Configurar vídeo avatar</h1>

  <% unless @has_heygen_key %>
    <div class="mb-6 rounded-card border border-semantic-warning/30 bg-semantic-warning-bg p-4 text-body-sm text-semantic-warning">
      Você ainda não configurou sua API Key HeyGen.
      <%= link_to "Configurar agora →", settings_media_generation_path,
            class: "font-medium underline hover:text-brand-primary-hover" %>
    </div>
  <% end %>

  <%= form_with url: content_suggestion_generated_medias_path(@content_suggestion),
                method: :post,
                data: { turbo: false } do |f| %>

    <div class="mb-5">
      <label class="mb-1 block text-body-sm font-medium text-text-body">Script do vídeo</label>
      <%= f.text_area :script,
            name: "generated_media[script]",
            rows: 6,
            value: @script,
            class: "block w-full rounded-input border border-border-default bg-surface-canvas px-3 py-2 text-body text-text-body placeholder:text-text-subtle focus:border-brand-primary focus:outline-none focus:shadow-focus" %>
      <p class="mt-1 text-caption text-text-muted">Edite o texto que o avatar vai falar.</p>
    </div>

    <div class="mb-5" data-controller="heygen-selector"
         data-heygen-selector-type-value="avatars"
         data-heygen-selector-url-value="<%= avatars_settings_media_generation_path %>">
      <label class="mb-1 block text-body-sm font-medium text-text-body">Avatar</label>
      <select name="generated_media[avatar_id]"
              data-heygen-selector-target="select"
              class="block w-full rounded-input border border-border-default bg-surface-canvas px-3 py-2 text-body text-text-body placeholder:text-text-subtle focus:border-brand-primary focus:outline-none focus:shadow-focus">
        <option value="">Carregando avatares...</option>
      </select>
    </div>

    <div class="mb-6" data-controller="heygen-selector"
         data-heygen-selector-type-value="voices"
         data-heygen-selector-url-value="<%= voices_settings_media_generation_path %>">
      <label class="mb-1 block text-body-sm font-medium text-text-body">Voz (pt-BR)</label>
      <select name="generated_media[voice_id]"
              data-heygen-selector-target="select"
              class="block w-full rounded-input border border-border-default bg-surface-canvas px-3 py-2 text-body text-text-body placeholder:text-text-subtle focus:border-brand-primary focus:outline-none focus:shadow-focus">
        <option value="">Carregando vozes...</option>
      </select>
    </div>

    <%= f.submit "Gerar vídeo",
          disabled: !@has_heygen_key,
          class: "w-full cursor-pointer rounded-pill bg-brand-primary px-4 py-3 text-button text-text-on-dark transition-all duration-[180ms] ease-out hover:bg-brand-primary-hover focus:outline-none focus:shadow-focus-strong disabled:cursor-not-allowed disabled:opacity-50 disabled:hover:bg-brand-primary" %>
  <% end %>
</div>
