<div class="mx-auto max-w-5xl">
  <header class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900">Vídeos gerados</h1>
      <p class="mt-1 text-sm text-gray-500"><%= @generated_medias.size %> mídia<%= @generated_medias.size == 1 ? "" : "s" %> encontrada<%= @generated_medias.size == 1 ? "" : "s" %></p>
    </div>

    <div class="flex gap-2">
      <% [nil, "completed", "processing", "pending", "failed"].each do |s| %>
        <%= link_to generated_medias_path(status: s),
              class: "rounded-md px-3 py-1.5 text-sm font-medium border #{params[:status].to_s == s.to_s ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-700 border-gray-300 hover:bg-gray-50'}" do %>
          <%= s.nil? ? "Todos" : s.capitalize %>
        <% end %>
      <% end %>
    </div>
  </header>

  <% if @generated_medias.empty? %>
    <div class="rounded-lg border border-dashed border-gray-300 py-16 text-center">
      <p class="text-gray-500">Nenhum vídeo gerado ainda.</p>
    </div>
  <% else %>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% @generated_medias.each do |media| %>
        <%= link_to generated_media_path(media), class: "group block rounded-lg border border-gray-200 bg-white p-4 shadow-sm hover:border-blue-400 hover:shadow-md transition-all" do %>
          <div class="mb-3 flex items-center justify-between">
            <%= render "generated_medias/status", generated_media: media %>
            <span class="text-xs text-gray-400"><%= l(media.created_at, format: :short) %></span>
          </div>

          <% suggestion = media.content_suggestion %>
          <p class="line-clamp-2 text-sm text-gray-700"><%= suggestion.hook.presence || suggestion.caption_draft&.truncate(100) || "Sem legenda" %></p>

          <% competitor = suggestion.analysis.competitor %>
          <p class="mt-2 text-xs text-gray-400">@<%= competitor.instagram_handle %></p>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
