<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <h1 class="text-display text-text-body">Meus Perfis</h1>
    <%= link_to "Adicionar Perfil", new_own_profile_path,
        class: "shrink-0 rounded-pill bg-brand-primary px-6 py-2.5 text-button text-text-on-dark transition-all duration-[180ms] ease-out hover:bg-brand-primary-hover hover:scale-[1.02] focus:outline-none focus:shadow-focus-strong inline-block" %>
  </div>

  <% if @own_profiles.empty? %>
    <div class="text-center py-16">
      <p class="text-body text-text-muted mb-6">Nenhum perfil cadastrado ainda.</p>
      <%= link_to "Adicionar meu perfil", new_own_profile_path,
          class: "rounded-pill bg-brand-primary px-6 py-2.5 text-button text-text-on-dark transition-all duration-[180ms] ease-out hover:bg-brand-primary-hover hover:scale-[1.02] focus:outline-none focus:shadow-focus-strong inline-block" %>
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @own_profiles.each do |profile| %>
        <div class="rounded-card border border-border-subtle bg-surface-canvas p-6 shadow-card space-y-4">
          <div class="flex items-start justify-between">
            <div>
              <p class="text-body font-semibold text-text-body">@<%= profile.instagram_handle %></p>
              <% if profile.full_name.present? %>
                <p class="text-body-sm text-text-muted"><%= profile.full_name %></p>
              <% end %>
            </div>
            <% if profile.token_valid? %>
              <% if profile.token_expiring_soon? %>
                <span class="inline-flex items-center gap-1.5 rounded-pill px-2 py-0.5 text-caption font-medium bg-semantic-warning-bg text-semantic-warning">Token expira em breve</span>
              <% else %>
                <span class="inline-flex items-center gap-1.5 rounded-pill px-2 py-0.5 text-caption font-medium bg-semantic-success-bg text-semantic-success">Token ativo</span>
              <% end %>
            <% else %>
              <span class="inline-flex items-center gap-1.5 rounded-pill px-2 py-0.5 text-caption font-medium bg-semantic-danger-bg text-semantic-danger">Token inválido</span>
            <% end %>
          </div>
          <div class="flex gap-2 pt-2">
            <%= link_to "Ver Dashboard", own_profile_path(profile),
                class: "flex-1 text-center rounded-pill bg-brand-primary px-4 py-2 text-button text-text-on-dark transition-all duration-[180ms] ease-out hover:bg-brand-primary-hover hover:scale-[1.02] focus:outline-none focus:shadow-focus-strong" %>
            <%= button_to "Sincronizar", sync_own_profile_path(profile),
                class: "flex-1 text-center rounded-pill bg-semantic-neutral-bg text-text-body hover:bg-surface-base px-4 py-2 text-button transition-colors" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
