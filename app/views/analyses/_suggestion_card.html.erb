<%= tag.div id: dom_id(suggestion),
    class: "rounded-feature border border-border-subtle bg-surface-canvas p-6 shadow-card",
    data: { controller: "copy-to-clipboard",
            copy_to_clipboard_hook_value: suggestion.hook.to_s,
            copy_to_clipboard_caption_value: suggestion.caption_draft.to_s,
            copy_to_clipboard_hashtags_value: (suggestion.suggested_hashtags || []).join(" ") } do %>
  <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
    <div class="flex items-center gap-3">
      <span class="rounded-pill bg-surface-base px-2.5 py-0.5 text-xs font-medium text-text-body">
        <%= t("post_type.#{suggestion.content_type}") %>
      </span>
      <span class="text-xs text-text-muted">#<%= suggestion.position %></span>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <button type="button"
              data-action="click->copy-to-clipboard#copy"
              data-copy-to-clipboard-target="button"
              class="rounded-pill border border-border-default bg-surface-canvas px-3 py-1 text-xs font-medium text-text-body transition-colors hover:border-brand-primary hover:text-brand-primary focus:outline-none focus:shadow-focus-strong">
        <span data-copy-to-clipboard-target="idle"><%= t("analyses.show.suggestions.copy") %></span>
        <span data-copy-to-clipboard-target="copied" class="hidden text-semantic-success"><%= t("analyses.show.suggestions.copied") %></span>
      </button>

      <% if suggestion.draft? %>
        <%= button_to t("analyses.show.suggestions.save"),
            content_suggestion_path(suggestion, content_suggestion: { status: "saved" }),
            method: :patch,
            class: "rounded-pill border border-semantic-success bg-semantic-success-bg px-3 py-1 text-xs font-medium text-semantic-success hover:brightness-95 focus:outline-none focus:shadow-focus-strong",
            form: { class: "inline" } %>
        <%= button_to t("analyses.show.suggestions.discard"),
            content_suggestion_path(suggestion, content_suggestion: { status: "discarded" }),
            method: :patch,
            class: "rounded-pill border border-border-default px-3 py-1 text-xs font-medium text-text-muted hover:bg-surface-base focus:outline-none focus:shadow-focus-strong",
            form: { class: "inline" } %>
      <% elsif suggestion.saved? %>
        <span class="text-xs font-medium text-semantic-success">&#10003; <%= t("analyses.show.suggestions.saved") %></span>
      <% elsif suggestion.discarded? %>
        <span class="text-xs font-medium text-text-muted"><%= t("analyses.show.suggestions.discarded") %></span>
      <% end %>
    </div>
  </div>

  <h4 class="mb-2 text-base font-semibold text-text-body"><%= suggestion.hook %></h4>

  <div class="mb-4 whitespace-pre-line text-body-sm text-text-body"><%= suggestion.caption_draft %></div>

  <% if suggestion.suggested_hashtags.present? %>
    <div class="mb-4 flex flex-wrap gap-2">
      <% suggestion.suggested_hashtags.each do |tag| %>
        <span class="rounded-pill bg-surface-base px-2 py-0.5 text-xs text-brand-primary">#<%= tag %></span>
      <% end %>
    </div>
  <% end %>

  <% if suggestion.format_details.present? %>
    <details class="mb-3 text-sm">
      <summary class="cursor-pointer text-text-muted hover:text-text-body">
        <%= t("analyses.show.suggestions.format_details") %>
      </summary>
      <%= render "analyses/format_details", suggestion: suggestion %>
    </details>
  <% end %>

  <% if suggestion.rationale.present? %>
    <details class="text-sm">
      <summary class="cursor-pointer text-text-muted hover:text-text-body">
        <%= t("analyses.show.suggestions.rationale") %>
      </summary>
      <p class="mt-2 text-xs text-text-muted"><%= suggestion.rationale %></p>
    </details>
  <% end %>

  <% last_media = suggestion.generated_medias.recent.first %>
  <%= render "generated_medias/suggestion_media_slot", suggestion: suggestion, last_media: last_media %>
<% end %>
