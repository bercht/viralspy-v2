<div class="min-h-screen flex flex-col md:flex-row">

  <%# ===== PAINEL ESQUERDO — Console Black ===== %>
  <div class="hidden md:flex w-1/2 bg-surface-dark flex-col justify-center p-12 lg:p-16">

    <%# Logo -%>
    <%= link_to root_path, class: "text-text-on-dark font-semibold text-lg tracking-tight" do %>
      ViralSpy
    <% end %>

    <%# Copy central -%>
    <div>
      <h1 class="text-4xl lg:text-[2.75rem] font-light text-text-on-dark leading-tight tracking-tight mb-4">
        Bem-vindo<br>de volta.
      </h1>
      <p class="text-base text-white/50 font-light leading-relaxed max-w-sm">
        Seus concorrentes não pararam de postar.<br>
        Continue de onde parou.
      </p>
    </div>

    <%# Destaque -%>
    <div class="border border-brand-primary/40 rounded-xl p-5 bg-brand-primary/5 max-w-sm">
      <div class="flex items-center gap-3">
        <span class="relative flex h-2.5 w-2.5">
          <span class="absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-75 animate-ping"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-brand-primary"></span>
        </span>
        <span class="text-sm text-white/60 font-light">Última análise pronta para você.</span>
      </div>
    </div>

  </div>

  <%# ===== PAINEL DIREITO — Paper White ===== %>
  <div class="w-full md:w-1/2 bg-surface-canvas flex flex-col justify-center px-6 py-10 md:px-10 lg:px-16">

    <%# Mobile logo -%>
    <div class="block md:hidden mb-6">
      <%= link_to root_path, class: "text-brand-primary font-semibold text-lg tracking-tight" do %>
        ViralSpy
      <% end %>
    </div>

    <div class="w-full max-w-sm mx-auto">

      <h2 class="text-2xl font-light text-text-display tracking-tight mb-8">
        Entrar na sua conta
      </h2>

      <%# Erros Devise -%>
      <% if resource.errors.any? %>
        <div class="mb-6 rounded-xl bg-semantic-danger-bg border border-semantic-danger/20 p-4">
          <ul class="space-y-1">
            <% resource.errors.full_messages.each do |msg| %>
              <li class="text-sm text-semantic-danger font-light"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Flash alerts -%>
      <% flash.each do |type, msg| %>
        <% next if msg.blank? %>
        <div class="mb-6 rounded-xl p-4 text-sm font-light <%= type.to_s == 'alert' ? 'bg-semantic-danger-bg text-semantic-danger border border-semantic-danger/20' : 'bg-semantic-info-bg text-brand-primary border border-brand-primary/20' %>">
          <%= msg %>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>

        <div>
          <%= f.label :email, "E-mail",
              class: "block text-xs font-medium text-text-muted tracking-wide uppercase mb-2" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true,
              class: "w-full border border-border-default rounded-xl px-4 py-3 text-sm text-text-body placeholder:text-text-subtle focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-shadow duration-150" %>
        </div>

        <div>
          <%= f.label :password, "Senha",
              class: "block text-xs font-medium text-text-muted tracking-wide uppercase mb-2" %>
          <%= f.password_field :password, autocomplete: "current-password", required: true,
              class: "w-full border border-border-default rounded-xl px-4 py-3 text-sm text-text-body placeholder:text-text-subtle focus:outline-none focus:ring-2 focus:ring-brand-primary focus:border-transparent transition-shadow duration-150" %>
        </div>

        <div class="flex items-center justify-between pt-1">
          <% if devise_mapping.rememberable? %>
            <label class="flex items-center gap-2 text-sm text-text-muted font-light cursor-pointer">
              <%= f.check_box :remember_me,
                  class: "rounded border-border-default text-brand-primary focus:ring-brand-primary" %>
              Lembrar de mim
            </label>
          <% else %>
            <span></span>
          <% end %>
          <%= link_to "Esqueci minha senha", new_password_path(resource_name),
              class: "text-sm text-brand-primary hover:text-brand-primary-hover font-light transition-colors duration-150" %>
        </div>

        <%= f.submit "Entrar",
            class: "w-full bg-brand-primary text-text-on-dark rounded-full py-3 text-sm font-medium tracking-wide hover:bg-brand-primary-hover hover:scale-[1.02] hover:ring-2 hover:ring-brand-primary hover:ring-offset-2 transition-all duration-150 ease-in-out cursor-pointer mt-2" %>

      <% end %>

      <p class="mt-6 text-center text-sm text-text-muted font-light">
        Não tem conta?
        <%= link_to "Criar conta grátis", new_registration_path(resource_name),
            class: "text-brand-primary hover:text-brand-primary-hover font-medium transition-colors duration-150" %>
      </p>

    </div>
  </div>

</div>
