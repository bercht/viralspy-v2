<div class="mx-auto max-w-5xl">
  <header class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-light text-text-heading">Vídeos gerados</h1>
      <p class="mt-1 text-body-sm text-text-muted"><%= @generated_medias.size %> mídia<%= @generated_medias.size == 1 ? "" : "s" %> encontrada<%= @generated_medias.size == 1 ? "" : "s" %></p>
    </div>

    <div class="flex flex-wrap gap-2">
      <% [nil, "completed", "processing", "pending", "failed"].each do |s| %>
        <%= link_to generated_medias_path(status: s),
              class: "rounded-pill px-3 py-1.5 text-sm font-medium border #{params[:status].to_s == s.to_s ? 'bg-brand-primary text-text-on-dark border-brand-primary' : 'bg-surface-base text-text-body border-border-subtle hover:bg-surface-raised'}" do %>
          <%= s.nil? ? "Todos" : s.capitalize %>
        <% end %>
      <% end %>
    </div>
  </header>

  <% if @generated_medias.empty? %>
    <div class="rounded-card border border-dashed border-border-subtle py-16 text-center">
      <p class="text-text-muted">Nenhum vídeo gerado ainda.</p>
    </div>
  <% else %>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% @generated_medias.each do |media| %>
        <%= link_to generated_media_path(media), class: "group block rounded-card border border-border-subtle bg-surface-base p-4 shadow-[0_5px_9px_0_rgba(0,0,0,0.06)] transition-all hover:border-brand-primary hover:shadow-[0_5px_9px_0_rgba(0,0,0,0.16)]" do %>
          <div class="mb-3 flex items-center justify-between">
            <%= render "generated_medias/status", generated_media: media %>
            <span class="text-caption text-text-muted"><%= l(media.created_at, format: :short) %></span>
          </div>

          <% suggestion = media.content_suggestion %>
          <p class="line-clamp-2 text-body-sm text-text-body"><%= suggestion.hook.presence || suggestion.caption_draft&.truncate(100) || "Sem legenda" %></p>

          <% competitor = suggestion.analysis.competitor %>
          <p class="mt-2 text-caption text-text-muted">@<%= competitor.instagram_handle %></p>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
