<div class="space-y-6">
  <%# BREADCRUMB %>
  <div class="flex items-center gap-2 text-body-sm text-text-muted">
    <%= link_to "Concorrentes", competitors_path, class: "hover:text-text-body" %>
    <span>/</span>
    <%= link_to "@#{@competitor.instagram_handle}", competitor_path(@competitor), class: "hover:text-text-body" %>
    <span>/</span>
    <span class="text-text-body">Stories</span>
  </div>

  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-display text-text-body">Stories observados</h1>
      <p class="text-body-sm text-text-muted mt-1">@<%= @competitor.instagram_handle %></p>
    </div>
    <%= link_to "Registrar observação", new_competitor_story_observation_path(@competitor),
        class: "rounded-pill bg-brand-primary px-6 py-2.5 text-button text-text-on-dark transition-all duration-[180ms] ease-out hover:bg-brand-primary-hover hover:scale-[1.02] focus:outline-none focus:shadow-focus-strong inline-block" %>
  </div>

  <% if @story_observations.empty? %>
    <div class="rounded-card border border-border-subtle bg-surface-canvas shadow-card p-8 text-center">
      <p class="text-body-sm text-text-muted">Nenhuma observação registrada ainda.</p>
      <p class="text-caption text-text-subtle mt-1">Registre manualmente os stories que você observar neste perfil.</p>
    </div>
  <% else %>
    <div class="rounded-card border border-border-subtle bg-surface-canvas shadow-card overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-surface-base border-b border-border-subtle">
          <tr>
            <th class="text-left px-4 py-3 text-caption font-medium text-text-muted">Data</th>
            <th class="text-left px-4 py-3 text-caption font-medium text-text-muted">Formato</th>
            <th class="text-left px-4 py-3 text-caption font-medium text-text-muted hidden md:table-cell">Tema</th>
            <th class="text-left px-4 py-3 text-caption font-medium text-text-muted hidden md:table-cell">Engajamento</th>
            <th class="text-left px-4 py-3 text-caption font-medium text-text-muted">Descrição</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border-subtle">
          <% @story_observations.each do |obs| %>
            <tr class="hover:bg-surface-base transition-colors">
              <td class="px-4 py-3 text-text-body whitespace-nowrap">
                <%= obs.observed_on.strftime("%d/%m/%Y") %>
              </td>
              <td class="px-4 py-3">
                <% if obs.format.present? %>
                  <span class="rounded-pill px-2 py-0.5 text-caption font-medium bg-semantic-neutral-bg text-semantic-neutral">
                    <%= obs.format.capitalize %>
                  </span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-text-muted hidden md:table-cell">
                <%= obs.theme %>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <% if obs.perceived_engagement.present? %>
                  <span class="rounded-pill px-2 py-0.5 text-caption font-medium
                    <%= obs.perceived_engagement == 'high'   ? 'bg-semantic-success-bg text-semantic-success' :
                        obs.perceived_engagement == 'medium' ? 'bg-semantic-warning-bg text-semantic-warning' :
                                                               'bg-semantic-neutral-bg text-semantic-neutral' %>">
                    <%= obs.perceived_engagement == 'high' ? 'Alto' :
                        obs.perceived_engagement == 'medium' ? 'Médio' : 'Baixo' %>
                  </span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-text-muted max-w-xs">
                <%= truncate(obs.description.to_s, length: 80) %>
              </td>
              <td class="px-4 py-3 text-right">
                <%= button_to "Remover", competitor_story_observation_path(@competitor, obs),
                    method: :delete,
                    data: { turbo_confirm: "Remover esta observação?" },
                    class: "text-caption text-semantic-danger hover:text-semantic-danger/80 bg-transparent border-0 cursor-pointer p-0" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
