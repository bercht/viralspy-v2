<nav class="bg-surface-dark" data-controller="mobile-menu">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-3 sm:py-4">
      <%= link_to authenticated_root_path, class: "flex items-center gap-2" do %>
        <span class="text-heading-sm font-semibold tracking-tight text-text-on-dark">ViralSpy</span>
      <% end %>

      <button type="button"
              class="md:hidden rounded p-2 text-text-on-dark-muted hover:text-text-on-dark focus:outline-none"
              data-action="click->mobile-menu#toggle"
              aria-label="Abrir menu de navegação">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>

      <div class="hidden md:flex items-center gap-6">
        <%= link_to t("nav.dashboard"), dashboard_path,
            class: "text-button text-text-on-dark-muted transition-colors hover:text-text-on-dark" %>
        <%= link_to t("nav.competitors"), competitors_path,
            class: "text-button text-text-on-dark-muted transition-colors hover:text-text-on-dark" %>
        <%= link_to t("nav.playbooks"), playbooks_path,
            class: "text-button text-text-on-dark-muted transition-colors hover:text-text-on-dark" %>
        <%= link_to t("nav.own_profiles"), own_profiles_path,
            class: "text-button text-text-on-dark-muted transition-colors hover:text-text-on-dark" %>
        <%= link_to t("nav.settings"), settings_api_keys_path,
            class: "text-button text-text-on-dark-muted transition-colors hover:text-text-on-dark" %>

        <div class="flex items-center gap-3 border-l border-white/20 pl-6">
          <span class="text-body-sm text-text-on-dark-muted"><%= current_user.first_name %></span>
          <%= button_to t("nav.logout"), destroy_user_session_path, method: :delete,
              class: "text-button text-text-on-dark-muted transition-colors hover:text-text-on-dark",
              form: { class: "inline" } %>
        </div>
      </div>
    </div>

    <div class="hidden border-t border-white/10 py-3 md:hidden" data-mobile-menu-target="nav">
      <div class="flex flex-col gap-1">
        <%= link_to t("nav.dashboard"), dashboard_path,
            class: "rounded px-2 py-2.5 text-body-sm text-text-on-dark-muted transition-colors hover:text-text-on-dark" %>
        <%= link_to t("nav.competitors"), competitors_path,
            class: "rounded px-2 py-2.5 text-body-sm text-text-on-dark-muted transition-colors hover:text-text-on-dark" %>
        <%= link_to t("nav.playbooks"), playbooks_path,
            class: "rounded px-2 py-2.5 text-body-sm text-text-on-dark-muted transition-colors hover:text-text-on-dark" %>
        <%= link_to t("nav.own_profiles"), own_profiles_path,
            class: "rounded px-2 py-2.5 text-body-sm text-text-on-dark-muted transition-colors hover:text-text-on-dark" %>
        <%= link_to t("nav.settings"), settings_api_keys_path,
            class: "rounded px-2 py-2.5 text-body-sm text-text-on-dark-muted transition-colors hover:text-text-on-dark" %>

        <div class="mt-2 flex items-center justify-between border-t border-white/10 pt-2">
          <span class="text-body-sm text-text-on-dark-muted"><%= current_user.first_name %></span>
          <%= button_to t("nav.logout"), destroy_user_session_path, method: :delete,
              class: "text-body-sm text-text-on-dark-muted transition-colors hover:text-text-on-dark",
              form: { class: "inline" } %>
        </div>
      </div>
    </div>
  </div>
</nav>
