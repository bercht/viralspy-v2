<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title>ViralSpy</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-white text-[#1f1f1f] antialiased font-sans">
    <% if user_signed_in? %>
      <%= render "shared/navbar" %>
    <% end %>

    <% if user_signed_in? && current_tenant.present? %>
      <% expiring = current_tenant.own_profiles.expiring_soon.first %>
      <% if expiring %>
        <div class="bg-amber-50 border-b border-amber-200 px-4 py-2.5 text-sm text-amber-800 flex items-center justify-between gap-4">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
            O token Meta do perfil <strong class="font-semibold">@<%= expiring.instagram_handle %></strong>
            expira em <%= expiring.meta_token_expires_at&.strftime("%d/%m/%Y") %>.
          </span>
          <%= link_to "Atualizar token", edit_own_profile_path(expiring),
              class: "shrink-0 font-semibold underline hover:text-amber-900 transition-colors" %>
        </div>
      <% end %>
    <% end %>

    <main class="mx-auto w-full max-w-[1600px] px-4 py-8 md:px-6 md:py-12 lg:px-12 lg:py-16 xl:px-16 xl:py-20">
      <div id="flash">
        <%= render "shared/flash" %>
      </div>
      <%= yield %>
    </main>

    <% if user_signed_in? %>
      <%= render "shared/footer" %>
    <% end %>
  </body>
</html>
