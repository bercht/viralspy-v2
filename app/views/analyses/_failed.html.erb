<article class="rounded-feature border border-semantic-danger/30 bg-semantic-danger-bg p-6 shadow-card md:p-8">
  <%= render "analyses/status_stepper",
      current_status: :failed,
      failed_step_status: analysis_failed_step_status(analysis) %>

  <div class="mt-6 text-center">
    <h2 class="text-heading text-semantic-danger"><%= t("analyses.show.failed.title") %></h2>
    <p class="mt-2 text-body text-text-body">
      <%= analysis.error_message.presence || t("analyses.show.failed.default_message") %>
    </p>

    <div class="mt-6">
      <%= link_to t("analyses.show.failed.retry"),
          new_competitor_analysis_path(competitor),
          class: "inline-block rounded-pill bg-brand-primary px-5 py-2 text-button text-text-on-dark transition-colors hover:bg-brand-primary-hover focus:outline-none focus:shadow-focus-strong" %>
    </div>
  </div>
</article>
