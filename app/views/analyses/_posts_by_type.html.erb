<div class="rounded-feature border border-border-subtle bg-surface-canvas p-6 shadow-card">
  <h3 class="mb-4 text-heading-sm uppercase tracking-wider text-text-muted">
    <%= t("post_type.#{type}_plural") %> (<%= posts.size %>)
  </h3>
  <div class="space-y-3">
    <% posts.each_with_index do |post, idx| %>
      <div class="flex gap-4 border-t border-border-subtle pt-3 first:border-t-0 first:pt-0">
        <div class="flex-shrink-0 text-body-sm font-medium text-text-muted">#<%= idx + 1 %></div>
        <div class="min-w-0 flex-1">
          <p class="line-clamp-2 text-body-sm text-text-body">
            <%= post.caption.presence || t("analyses.show.top_posts.no_caption") %>
          </p>
          <div class="mt-2 flex items-center gap-4 text-xs text-text-muted">
            <span><%= number_with_delimiter(post.likes_count) %> <%= t("analyses.show.top_posts.likes") %></span>
            <span><%= number_with_delimiter(post.comments_count) %> <%= t("analyses.show.top_posts.comments") %></span>
            <% if post.video_view_count.present? %>
              <span><%= number_with_delimiter(post.video_view_count) %> <%= t("analyses.show.top_posts.views") %></span>
            <% end %>
            <span class="ml-auto font-medium text-text-body">
              <%= t("analyses.show.top_posts.score") %>: <%= post.quality_score&.round(2) || "—" %>
            </span>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
