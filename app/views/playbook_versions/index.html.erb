<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to "← #{@playbook.name}", @playbook, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>
  <h1 class="text-xl font-bold text-gray-900 mb-6">Todas as versões</h1>
  <div class="space-y-3">
    <% @versions.each do |version| %>
      <div class="bg-white border border-gray-200 rounded-lg p-4 flex items-center justify-between">
        <div>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-800 mr-2">
            v<%= version.version_number %>
          </span>
          <span class="text-sm text-gray-700"><%= version.diff_summary&.truncate(80) %></span>
          <p class="text-xs text-gray-400 mt-1"><%= version.created_at.strftime("%d/%m/%Y às %H:%M") %></p>
        </div>
        <%= link_to "Ver", playbook_version_path(version), class: "text-sm text-indigo-600 hover:text-indigo-800" %>
      </div>
    <% end %>
  </div>
</div>
