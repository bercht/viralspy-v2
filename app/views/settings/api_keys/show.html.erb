<div class="mx-auto max-w-4xl">
  <header class="mb-8">
    <h1 class="text-display text-text-display"><%= t("settings.api_keys.title") %></h1>
    <p class="mt-2 text-body text-text-muted"><%= t("settings.api_keys.subtitle") %></p>
  </header>

  <%= render "settings/navigation" %>

  <% if @credentials_by_provider.values.none?(&:present?) %>
    <section class="mb-6 rounded-feature border border-border-subtle bg-surface-canvas p-6 shadow-card">
      <h2 class="text-heading text-text-body"><%= t("settings.api_keys.empty.title") %></h2>
      <p class="mt-2 text-body text-text-muted"><%= t("settings.api_keys.empty.description") %></p>
      <p class="mt-4 text-body-sm text-text-muted"><%= t("settings.api_keys.empty.providers_needed") %></p>
    </section>
  <% end %>

  <div class="space-y-4">
    <% @credentials_by_provider.each do |provider, credential| %>
      <%= render "provider_card", provider: provider, credential: credential %>
    <% end %>
  </div>
</div>
