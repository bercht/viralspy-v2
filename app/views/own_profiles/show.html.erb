<%# TOKEN EXPIRY BANNER %>
<% if @own_profile.token_expiring_soon? && @own_profile.token_valid? %>
  <div class="mb-6 rounded-card border border-semantic-warning/30 bg-semantic-warning-bg px-4 py-3 flex items-center justify-between">
    <span class="text-body-sm text-semantic-warning">
      &#x26A0;&#xFE0F; Token Meta expira em <%= @own_profile.meta_token_expires_at&.strftime("%d/%m/%Y") %>.
    </span>
    <%= link_to "Atualizar token", edit_own_profile_path(@own_profile),
        class: "text-body-sm font-medium text-semantic-warning underline hover:text-semantic-warning/80" %>
  </div>
<% end %>

<div class="space-y-8">
  <%# HEADER %>
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="text-display text-text-body">@<%= @own_profile.instagram_handle %></h1>
        <% if @own_profile.token_valid? %>
          <% if @own_profile.token_expiring_soon? %>
            <span class="inline-flex items-center gap-1.5 rounded-pill px-2 py-0.5 text-caption font-medium bg-semantic-warning-bg text-semantic-warning">Token expira em breve</span>
          <% else %>
            <span class="inline-flex items-center gap-1.5 rounded-pill px-2 py-0.5 text-caption font-medium bg-semantic-success-bg text-semantic-success">Token ativo</span>
          <% end %>
        <% else %>
          <span class="inline-flex items-center gap-1.5 rounded-pill px-2 py-0.5 text-caption font-medium bg-semantic-danger-bg text-semantic-danger">Token inválido</span>
        <% end %>
      </div>
      <% if @own_profile.full_name.present? %>
        <p class="text-text-muted mt-1"><%= @own_profile.full_name %></p>
      <% end %>
    </div>
    <div class="flex gap-3">
      <%= button_to "Sincronizar posts", sync_own_profile_path(@own_profile),
          class: "rounded-pill bg-brand-primary px-5 py-2 text-button text-text-on-dark transition-all duration-[180ms] ease-out hover:bg-brand-primary-hover hover:scale-[1.02] focus:outline-none focus:shadow-focus-strong" %>
      <%= link_to "Editar perfil", edit_own_profile_path(@own_profile),
          class: "rounded-pill bg-surface-canvas text-text-body border border-border-subtle px-5 py-2 text-button transition-colors hover:bg-surface-base" %>
    </div>
  </div>

  <%# MÉTRICAS AGREGADAS %>
  <% if @metrics_summary.any? %>
    <div>
      <h2 class="text-heading text-text-body mb-4">Métricas</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="rounded-card border border-border-subtle bg-surface-canvas p-6 shadow-card">
          <p class="text-display text-text-body"><%= @metrics_summary[:total_posts] %></p>
          <p class="text-body-sm text-text-muted mt-1">Posts totais</p>
        </div>
        <div class="rounded-card border border-border-subtle bg-surface-canvas p-6 shadow-card">
          <p class="text-display text-text-body"><%= number_with_delimiter(@metrics_summary[:avg_reach]) %></p>
          <p class="text-body-sm text-text-muted mt-1">Alcance médio</p>
        </div>
        <% if @metrics_summary[:avg_plays] %>
          <div class="rounded-card border border-border-subtle bg-surface-canvas p-6 shadow-card">
            <p class="text-display text-text-body"><%= number_with_delimiter(@metrics_summary[:avg_plays]) %></p>
            <p class="text-body-sm text-text-muted mt-1">Plays médios (reels)</p>
          </div>
        <% end %>
        <% if @metrics_summary[:avg_engagement] %>
          <div class="rounded-card border border-border-subtle bg-surface-canvas p-6 shadow-card">
            <p class="text-display text-text-body"><%= number_to_percentage(@metrics_summary[:avg_engagement] * 100, precision: 1) %></p>
            <p class="text-body-sm text-text-muted mt-1">Engajamento médio</p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# TOP POST %>
  <% if (top = @metrics_summary[:top_post]) %>
    <div class="rounded-card border border-brand-primary/30 bg-surface-canvas p-6 shadow-card">
      <h3 class="text-caption font-medium text-brand-primary mb-3">Melhor post por alcance</h3>
      <p class="text-body-sm text-text-body mb-4"><%= truncate(top.caption.to_s, length: 120) %></p>
      <div class="grid grid-cols-3 gap-4">
        <div>
          <p class="text-heading text-text-body"><%= number_with_delimiter(top.metrics["reach"]) %></p>
          <p class="text-caption text-text-muted">Alcance</p>
        </div>
        <div>
          <p class="text-heading text-text-body"><%= number_with_delimiter(top.metrics["plays"]) %></p>
          <p class="text-caption text-text-muted">Plays</p>
        </div>
        <div>
          <p class="text-heading text-text-body"><%= number_with_delimiter(top.metrics["saves"]) %></p>
          <p class="text-caption text-text-muted">Saves</p>
        </div>
      </div>
    </div>
  <% end %>

  <%# POSTS RECENTES %>
  <div>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-heading text-text-body">Posts recentes</h2>
      <%= link_to "Ver todos", own_profile_own_posts_path(@own_profile),
          class: "text-body-sm text-brand-primary hover:text-brand-primary-hover" %>
    </div>

    <% if @own_posts.empty? %>
      <div class="rounded-card border border-border-subtle bg-surface-canvas p-8 text-center shadow-card">
        <p class="text-body-sm text-text-muted">Nenhum post sincronizado ainda.</p>
        <p class="text-caption text-text-subtle mt-1">Clique em "Sincronizar posts" para importar seus posts do Instagram.</p>
      </div>
    <% else %>
      <div class="rounded-card border border-border-subtle bg-surface-canvas shadow-card overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-surface-base border-b border-border-subtle">
            <tr>
              <th class="text-left px-4 py-3 text-caption font-medium text-text-muted">Post</th>
              <th class="text-left px-4 py-3 text-caption font-medium text-text-muted hidden md:table-cell">Data</th>
              <th class="text-right px-4 py-3 text-caption font-medium text-text-muted">Alcance</th>
              <th class="text-right px-4 py-3 text-caption font-medium text-text-muted hidden md:table-cell">Engajamento</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border-subtle">
            <% @own_posts.each do |post| %>
              <tr class="hover:bg-surface-base transition-colors">
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2">
                    <span class="rounded-pill px-2 py-0.5 text-caption font-medium bg-semantic-neutral-bg text-semantic-neutral">
                      <%= post.post_type.capitalize %>
                    </span>
                    <span class="text-text-body truncate max-w-xs"><%= truncate(post.caption.to_s, length: 50) %></span>
                  </div>
                </td>
                <td class="px-4 py-3 text-text-muted hidden md:table-cell">
                  <%= post.posted_at&.strftime("%d/%m/%Y") %>
                </td>
                <td class="px-4 py-3 text-right text-text-body">
                  <%= number_with_delimiter(post.metrics["reach"]) %>
                </td>
                <td class="px-4 py-3 text-right text-text-muted hidden md:table-cell">
                  <% if post.metrics["engagement_rate"] %>
                    <%= number_to_percentage(post.metrics["engagement_rate"].to_f * 100, precision: 1) %>
                  <% else %>
                    <span class="text-text-subtle">&mdash;</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-right">
                  <%= link_to "Avaliar", edit_own_profile_own_post_path(@own_profile, post),
                      class: "text-caption text-brand-primary hover:text-brand-primary-hover" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
