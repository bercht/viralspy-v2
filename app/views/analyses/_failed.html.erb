<article class="rounded-feature border border-semantic-danger/30 bg-semantic-danger-bg p-8 text-center shadow-card md:p-12">
  <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-semantic-danger/10">
    <svg class="h-6 w-6 text-semantic-danger" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </div>
  <h2 class="text-heading text-semantic-danger"><%= t("analyses.show.failed.title") %></h2>
  <p class="mt-2 text-body text-text-body">
    <%= analysis.error_message.presence || t("analyses.show.failed.default_message") %>
  </p>

  <div class="mt-6">
    <%= link_to t("analyses.show.failed.retry"),
        new_competitor_analysis_path(competitor),
        class: "inline-block rounded-pill bg-brand-primary px-5 py-2 text-button text-text-on-dark transition-colors hover:bg-brand-primary-hover focus:outline-none focus:shadow-focus-strong" %>
  </div>
</article>
