<%= tag.li id: "analysis-row-#{analysis.id}",
          class: "px-6 #{analysis.expired? ? 'border-l-4 border-red-500' : ''}" do %>
  <%= link_to competitor_analysis_path(competitor, analysis),
      class: "flex items-center justify-between transition-colors hover:bg-surface-base -mx-2 px-2 py-4 rounded-sm" do %>
    <div>
      <p class="text-body-sm font-medium text-text-body"><%= l(analysis.created_at, format: :long) %></p>
      <p class="text-caption text-text-muted">
        <%= t("competitors.show.posts_scraped", count: analysis.posts_scraped_count || 0) %>
      </p>
    </div>
    <%= render "shared/status_badge", status: analysis.status %>
  <% end %>
  <%= render "analyses/expiry_banner", analysis: analysis %>
<% end %>
