<% container_classes = if generated_media.completed?
     "border border-semantic-success/30 bg-semantic-success-bg"
   elsif generated_media.failed?
     "border border-semantic-danger/30 bg-semantic-danger-bg"
   else
     "border border-border-subtle bg-surface-base"
   end %>
<div id="generated_media_<%= generated_media.id %>"
     class="mt-3 rounded-card p-3 <%= container_classes %>">

  <% if generated_media.pending? || generated_media.processing? %>
    <div class="flex items-center gap-2">
      <div class="h-4 w-4 animate-spin rounded-full border-2 border-brand-primary border-t-transparent" aria-hidden="true"></div>
      <span class="text-body-sm text-text-muted">Gerando vídeo... pode levar alguns minutos.</span>
    </div>

  <% elsif generated_media.completed? %>
    <div class="flex items-center justify-between">
      <span class="text-body-sm font-medium text-semantic-success">✓ Vídeo gerado</span>
      <a href="<%= generated_media.output_url %>"
         target="_blank"
         rel="noopener noreferrer"
         class="rounded-pill bg-brand-primary px-3 py-1 text-button text-text-on-dark
                transition-all duration-[180ms] ease-out
                hover:bg-brand-primary-hover hover:scale-[1.02]
                focus:outline-none focus:shadow-focus"
         aria-label="Abrir vídeo gerado em nova aba">
        Abrir vídeo
      </a>
    </div>
    <p class="mt-1 text-caption text-text-muted">Link válido por ~7 dias. Faça download para guardar.</p>

  <% elsif generated_media.failed? %>
    <div>
      <span class="text-body-sm font-medium text-semantic-danger">✗ Falha na geração</span>
      <p class="mt-0.5 text-caption text-semantic-danger"><%= generated_media.error_message %></p>
    </div>
  <% end %>
</div>
