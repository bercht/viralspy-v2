<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-gray-900"><%= t("competitors.index.title") %></h1>
    <p class="mt-1 text-sm text-gray-600"><%= t("competitors.index.subtitle") %></p>
  </div>
  <%= link_to t("competitors.index.new"), new_competitor_path,
      class: "rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-800" %>
</div>

<% if @competitors.any? %>
  <div class="overflow-hidden rounded-lg border border-gray-200 bg-white">
    <table class="w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t("competitors.index.handle") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t("competitors.index.analyses") %></th>
          <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500"><%= t("competitors.index.added") %></th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 bg-white">
        <% @competitors.each do |competitor| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 text-sm font-medium text-gray-900">
              <%= link_to "@#{competitor.instagram_handle}", competitor_path(competitor), class: "hover:underline" %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-600"><%= competitor.analyses.size %></td>
            <td class="px-6 py-4 text-sm text-gray-600"><%= l(competitor.created_at, format: :short) %></td>
            <td class="px-6 py-4 text-right">
              <%= link_to t("competitors.index.view"), competitor_path(competitor),
                  class: "text-sm font-medium text-gray-700 hover:text-gray-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="rounded-lg border border-dashed border-gray-300 bg-white p-12 text-center">
    <p class="text-sm text-gray-500"><%= t("competitors.index.empty") %></p>
    <%= link_to t("competitors.index.new"), new_competitor_path,
        class: "mt-4 inline-flex rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-800" %>
  </div>
<% end %>
