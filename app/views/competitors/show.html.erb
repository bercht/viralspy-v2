<%= turbo_stream_from "competitor_#{@competitor.id}_analyses" %>

<div class="mx-auto max-w-4xl">
  <header class="mb-8">
    <%= link_to t("competitors.index.title"), competitors_path,
        class: "text-body-sm text-brand-primary hover:text-brand-primary-hover" %>

    <div class="mt-2 flex items-start justify-between gap-4">
      <div class="min-w-0">
        <h1 class="text-display text-text-display">@<%= @competitor.instagram_handle %></h1>
        <p class="mt-2 text-body-sm text-text-muted">
          <% if @competitor.followers_count.present? %>
            <%= number_with_delimiter(@competitor.followers_count) %> <%= t("competitors.show.followers") %>
          <% else %>
            <%= t("competitors.show.no_data_yet") %>
          <% end %>
        </p>
      </div>

      <div class="flex flex-wrap shrink-0 items-center gap-2">
        <%= button_to t("competitors.show.new_analysis"),
            competitor_analyses_path(@competitor), method: :post,
            class: "rounded-pill bg-brand-primary px-5 py-2 text-button text-text-on-dark transition-colors hover:bg-brand-primary-hover focus:outline-none focus:shadow-focus-strong",
            form: { class: "inline" } %>

        <%= button_to t("competitors.show.delete"),
            competitor_path(@competitor), method: :delete,
            data: { turbo_confirm: t("competitors.show.delete_confirm") },
            class: "rounded-pill px-4 py-2 text-button text-semantic-danger transition-colors hover:bg-semantic-danger-bg",
            form: { class: "inline" } %>
      </div>
    </div>
  </header>

  <section class="rounded-card border border-border-subtle bg-surface-canvas shadow-card">
    <div class="border-b border-border-subtle px-6 py-4">
      <h2 class="text-heading text-text-body"><%= t("competitors.show.analyses_history") %></h2>
    </div>

    <% if @analyses.any? %>
      <ul class="divide-y divide-border-subtle">
        <% @analyses.each do |analysis| %>
          <%= render "analyses/list_item", analysis: analysis, competitor: @competitor %>
        <% end %>
      </ul>
    <% else %>
      <div class="p-8 text-center md:p-12">
        <h3 class="text-heading text-text-body"><%= t("competitors.show.no_analyses.title") %></h3>
        <p class="mt-2 text-body-sm text-text-muted"><%= t("competitors.show.no_analyses.description") %></p>
        <%= link_to t("competitors.show.no_analyses.cta"),
            new_competitor_analysis_path(@competitor),
            class: "mt-6 inline-block rounded-pill bg-brand-primary px-6 py-2 text-button text-text-on-dark transition-colors hover:bg-brand-primary-hover focus:outline-none focus:shadow-focus-strong" %>
      </div>
    <% end %>
  </section>
</div>
