<% badge_classes = case status.to_sym
   when :pending, :scraping, :scoring, :transcribing, :analyzing, :generating_suggestions
     "bg-blue-100 text-blue-800"
   when :completed
     "bg-emerald-100 text-emerald-800"
   when :failed
     "bg-red-100 text-red-800"
   else
     "bg-gray-100 text-gray-800"
   end %>

<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= badge_classes %>">
  <%= t("analysis.status.#{status}") %>
</span>
