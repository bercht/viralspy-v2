<% if analysis.expired? %>
  <div id="analysis-expiry-<%= analysis.id %>"
       class="border-l-4 border-semantic-danger bg-semantic-danger-bg px-4 py-3
              flex flex-col sm:flex-row sm:items-center justify-between gap-3">
    <p class="text-body-sm text-text-body">
      Análise expirada em <%= l(analysis.expires_at, format: :short) %>.
      Os insights podem estar desatualizados.
    </p>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Re-analisar",
            new_competitor_analysis_path(analysis.competitor),
            class: "rounded-pill bg-brand-primary px-4 py-1.5 text-button text-text-on-dark
                    transition-all duration-[180ms] ease-out
                    hover:bg-brand-primary-hover hover:scale-[1.02]
                    focus:outline-none focus:shadow-focus" %>

      <%= button_to "Manter por mais 30 dias",
            extend_expiry_competitor_analysis_path(analysis.competitor, analysis),
            method: :post,
            class: "rounded-pill border border-brand-primary px-4 py-1.5 text-button text-brand-primary
                    transition-all duration-[180ms] ease-out
                    hover:bg-semantic-info-bg
                    focus:outline-none focus:shadow-focus" %>

      <%= button_to "Descartar",
            discard_competitor_analysis_path(analysis.competitor, analysis),
            method: :delete,
            data: { turbo_confirm: "Descartar esta análise? Posts e sugestões serão removidos. O Playbook não é afetado." },
            class: "text-button text-semantic-danger underline transition-colors duration-[180ms]
                    hover:text-semantic-danger/80" %>
    </div>
  </div>
<% elsif analysis.expiring_soon? %>
  <div id="analysis-expiry-<%= analysis.id %>"
       class="border-l-4 border-semantic-warning bg-semantic-warning-bg px-4 py-2">
    <p class="text-body-sm text-text-body">
      Esta análise expira em <%= l(analysis.expires_at, format: :short) %>.
    </p>
  </div>
<% else %>
  <div id="analysis-expiry-<%= analysis.id %>"></div>
<% end %>
