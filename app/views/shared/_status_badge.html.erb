<% badge_classes = case status.to_sym
   when :pending, :scraping, :scoring, :transcribing, :analyzing, :generating_suggestions, :refining
     "bg-semantic-info-bg text-semantic-info"
   when :completed
     "bg-semantic-success-bg text-semantic-success"
   when :failed
     "bg-semantic-danger-bg text-semantic-danger"
   else
     "bg-semantic-neutral-bg text-semantic-neutral"
   end %>
<span class="inline-flex items-center rounded-pill px-2.5 py-0.5 text-caption <%= badge_classes %>">
  <%= t("analysis.status.#{status}") %>
</span>
