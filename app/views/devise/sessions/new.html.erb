<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8">
      <h1 class="text-2xl font-semibold text-gray-900 mb-6"><%= t('devise.sessions.new.title') %></h1>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <div>
          <%= f.label :email, t('devise.registrations.email_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true,
                class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        </div>

        <div>
          <%= f.label :password, t('devise.registrations.password_label'), class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "current-password", required: true,
                class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        </div>

        <div class="flex items-center justify-between">
          <% if devise_mapping.rememberable? %>
            <label class="flex items-center gap-2 text-sm text-gray-600">
              <%= f.check_box :remember_me, class: "rounded border-gray-300 text-indigo-600" %>
              Lembrar de mim
            </label>
          <% end %>
          <%= link_to t('devise.sessions.new.forgot_password'), new_password_path(resource_name), class: "text-sm text-indigo-600 hover:text-indigo-700" %>
        </div>

        <%= f.submit t('devise.sessions.new.submit'),
              class: "w-full rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 cursor-pointer" %>
      <% end %>

      <div class="mt-6 text-center text-sm text-gray-600">
        <%= link_to t('devise.sessions.new.no_account'), new_registration_path(resource_name), class: "text-indigo-600 hover:text-indigo-700" %>
      </div>
    </div>
  </div>
</div>
