<article class="rounded-feature border border-border-subtle bg-surface-canvas p-6 shadow-card md:p-8">
  <%= render "analyses/status_stepper", current_status: analysis.status.to_sym, failed_step_status: nil %>

  <div class="mt-6 text-center">
    <h2 class="text-heading text-text-body"><%= t("analyses.status.#{analysis.status}") %></h2>
    <p class="mt-2 text-body text-text-muted"><%= t("analyses.show.in_progress.realtime_hint") %></p>
  </div>
</article>
