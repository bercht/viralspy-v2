<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <h1 class="text-display text-text-body">Playbooks</h1>
    <%= link_to "Novo Playbook", new_playbook_path,
        class: "shrink-0 inline-flex items-center rounded-pill bg-brand-primary px-4 py-2 text-button text-text-on-dark transition-all duration-[180ms] ease-out hover:bg-brand-primary-hover hover:scale-[1.02] focus:outline-none focus:shadow-focus-strong" %>
  </div>

  <% if @playbooks.empty? %>
    <div class="text-center py-16 text-text-muted">
      <p class="text-body">Nenhum playbook ainda.</p>
      <p class="text-body-sm mt-2">Crie um playbook para começar a acumular conhecimento sobre seu nicho.</p>
    </div>
  <% else %>
    <div class="space-y-4">
      <% @playbooks.each do |playbook| %>
        <div class="bg-surface-canvas border border-border-subtle rounded-card p-5 hover:border-brand-primary/40 transition-colors shadow-card">
          <div class="flex items-start justify-between">
            <div>
              <%= link_to playbook.name, playbook,
                  class: "text-heading font-semibold text-text-body hover:text-brand-primary-hover" %>
              <% if playbook.niche.present? %>
                <p class="text-body-sm text-text-muted mt-1"><%= playbook.niche %></p>
              <% end %>
            </div>
            <div class="text-right">
              <% if playbook.current_version_number > 0 %>
                <span class="inline-flex items-center rounded-pill px-2 py-0.5 text-caption font-medium bg-semantic-success-bg text-semantic-success">
                  v<%= playbook.current_version_number %>
                </span>
              <% else %>
                <span class="inline-flex items-center rounded-pill px-2 py-0.5 text-caption font-medium bg-semantic-neutral-bg text-semantic-neutral">
                  Sem versão
                </span>
              <% end %>
              <p class="text-caption text-text-subtle mt-1">Atualizado <%= time_ago_in_words(playbook.updated_at) %> atrás</p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
