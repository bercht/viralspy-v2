<div class="space-y-6">
  <%# BREADCRUMB %>
  <div class="flex items-center gap-2 text-sm text-slate-500">
    <%= link_to "Meus Perfis", own_profiles_path, class: "hover:text-slate-700" %>
    <span>/</span>
    <%= link_to "@#{@own_profile.instagram_handle}", own_profile_path(@own_profile), class: "hover:text-slate-700" %>
    <span>/</span>
    <span class="text-slate-900">Posts</span>
  </div>

  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-light text-slate-900">Posts de @<%= @own_profile.instagram_handle %></h1>
  </div>

  <%# TYPE FILTER %>
  <div class="flex gap-2 flex-wrap">
    <%= link_to "Todos", own_profile_own_posts_path(@own_profile),
        class: "rounded-full px-4 py-1.5 text-sm font-medium transition-all #{params[:type].blank? ? 'bg-blue-600 text-white' : 'bg-white border border-slate-200 text-slate-600 hover:border-slate-300'}" %>
    <% %w[reel carousel image].each do |type| %>
      <%= link_to type.capitalize, own_profile_own_posts_path(@own_profile, type: type),
          class: "rounded-full px-4 py-1.5 text-sm font-medium transition-all #{params[:type] == type ? 'bg-blue-600 text-white' : 'bg-white border border-slate-200 text-slate-600 hover:border-slate-300'}" %>
    <% end %>
  </div>

  <% if @own_posts.empty? %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-8 text-center">
      <p class="text-slate-500">Nenhum post encontrado.</p>
    </div>
  <% else %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
          <tr>
            <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wide">Post</th>
            <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wide hidden md:table-cell">Data</th>
            <th class="text-right px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wide">Alcance</th>
            <th class="text-right px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wide hidden md:table-cell">Plays</th>
            <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wide hidden md:table-cell">Avaliação</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @own_posts.each do |post| %>
            <tr class="hover:bg-slate-50 transition-colors">
              <td class="px-4 py-3">
                <div class="flex items-center gap-2">
                  <span class="rounded-full text-xs px-2 py-0.5 font-medium
                    <%= post.reel? ? 'bg-purple-100 text-purple-700' :
                        post.carousel? ? 'bg-blue-100 text-blue-700' :
                        'bg-slate-100 text-slate-600' %>">
                    <%= post.post_type.capitalize %>
                  </span>
                  <span class="text-slate-700 truncate max-w-xs"><%= truncate(post.caption.to_s, length: 60) %></span>
                </div>
              </td>
              <td class="px-4 py-3 text-slate-500 hidden md:table-cell">
                <%= post.posted_at&.strftime("%d/%m/%Y") %>
              </td>
              <td class="px-4 py-3 text-right text-slate-700">
                <%= number_with_delimiter(post.metrics["reach"]) %>
              </td>
              <td class="px-4 py-3 text-right text-slate-500 hidden md:table-cell">
                <%= number_with_delimiter(post.metrics["plays"]) %>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <% if post.performance_rating %>
                  <span class="rounded-full text-xs px-2 py-0.5 font-medium
                    <%= post.rating_breakthrough? ? 'bg-green-100 text-green-700' :
                        post.rating_good? ? 'bg-blue-100 text-blue-700' :
                        post.rating_average? ? 'bg-yellow-100 text-yellow-700' :
                        'bg-red-100 text-red-700' %>">
                    <%= post.performance_rating.capitalize %>
                  </span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-right">
                <%= link_to "Ver", own_profile_own_post_path(@own_profile, post),
                    class: "text-xs text-blue-600 hover:text-sky-400 mr-2" %>
                <%= link_to "Avaliar", edit_own_profile_own_post_path(@own_profile, post),
                    class: "text-xs text-slate-500 hover:text-slate-700" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
