<div class="mx-auto max-w-4xl">
  <header class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-display text-text-display"><%= t("competitors.index.title") %></h1>
      <p class="mt-2 text-body text-text-muted"><%= t("competitors.index.subtitle") %></p>
    </div>
    <%= link_to t("competitors.index.new"), new_competitor_path,
        class: "rounded-pill bg-brand-primary px-5 py-2 text-button text-text-on-dark transition-colors hover:bg-brand-primary-hover focus:outline-none focus:shadow-focus-strong" %>
  </header>

  <% if @competitors.any? %>
    <div class="space-y-3">
      <% @competitors.each do |competitor| %>
        <%= link_to competitor_path(competitor),
            class: "block rounded-card border border-border-subtle bg-surface-canvas p-5 shadow-card transition-all hover:shadow-raised hover:border-brand-primary/30" do %>
          <div class="flex items-center justify-between gap-4">
            <div class="min-w-0">
              <p class="text-heading-sm font-semibold text-text-body">@<%= competitor.instagram_handle %></p>
              <p class="mt-1 text-caption text-text-muted">
                <%= t("dashboard.analyses_count", count: competitor.analyses.size) %>
                &middot; <%= t("competitors.index.added") %> <%= l(competitor.created_at, format: :short) %>
              </p>
            </div>
            <span class="shrink-0 text-body-sm text-text-subtle" aria-hidden="true">&rarr;</span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-card border border-border-subtle bg-surface-canvas p-12 text-center shadow-card">
      <h2 class="text-heading text-text-body"><%= t("competitors.index.empty") %></h2>
      <p class="mx-auto mt-2 max-w-md text-body text-text-muted">
        <%= t("competitors.index.subtitle") %>
      </p>
      <%= link_to t("competitors.index.new"), new_competitor_path,
          class: "mt-6 inline-block rounded-pill bg-brand-primary px-6 py-2.5 text-button text-text-on-dark transition-colors hover:bg-brand-primary-hover focus:outline-none focus:shadow-focus-strong" %>
    </div>
  <% end %>
</div>
