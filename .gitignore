# Ignore bundler config.
/.bundle

# Environment files — nunca commitar, apenas o exemplo e o template de prod
.env
.env.*
!.env.example
!.env.production

# Logfiles e tempfiles
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Pids
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Storage
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Assets compilados
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Credentials
/config/master.key
/config/credentials/*.key

# Coverage
/coverage

# Dependências
node_modules/
vendor/bundle/
.worktrees/
