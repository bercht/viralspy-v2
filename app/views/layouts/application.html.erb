<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title>ViralSpy</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
    <% if notice.present? %>
      <div class="mx-auto max-w-3xl px-4 pt-4">
        <div class="rounded-md bg-green-50 p-4 text-sm text-green-800 border border-green-200">
          <%= notice %>
        </div>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="mx-auto max-w-3xl px-4 pt-4">
        <div class="rounded-md bg-red-50 p-4 text-sm text-red-800 border border-red-200">
          <%= alert %>
        </div>
      </div>
    <% end %>
    <%= yield %>
  </body>
</html>
